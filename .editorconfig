root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,md}]
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx,vue}]
indent_size = 2

[*.{css,scss}]
indent_size = 2

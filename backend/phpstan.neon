parameters:
    level: max
    paths:
        - app/
        - database/factories/
        - database/seeders/
    excludePaths:
        - app/Modules/Shared/Http/Middleware/RequestId.php
        - config/sanctum.php
        - config/permission.php
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    parallel:
        maximumNumberOfProcesses: 4
includes:
    - vendor/larastan/larastan/extension.neon

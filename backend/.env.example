APP_NAME="Civic Intelligence Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

APP_LIVEWIRE=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cip
DB_USERNAME=cip
DB_PASSWORD=cip
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_ENGINE=InnoDB
DB_STRICT=true

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# MinIO (S3-compatible) for evidence media
AWS_ACCESS_KEY_ID=cipminio
AWS_SECRET_ACCESS_KEY=cipminio-secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=cip-evidence
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/cip-evidence
AWS_USE_PATH_STYLE_ENDPOINT=true

# Mail (dev: log; staging/prod: smtp)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@cip.local"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
SESSION_DOMAIN=localhost

# Cache
CACHE_PREFIX=cip_

# Telescope (disabled in CI)
TELESCOPE_ENABLED=false

# Horizon
HORIZON_PREFIX=cip_horizon:

# AI provider defaults (overridable via admin)
AI_DEFAULT_PROVIDER=modal-vision

# Modal.com vLLM endpoint (vision-capable model)
# Modal proxy auth uses Modal-Key / Modal-Secret headers.
AI_MODAL_BASE_URL=https://akshayjoshi999--cip-vision-v3-serve.modal.run
AI_MODAL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
AI_MODAL_KEY=
AI_MODAL_SECRET=

# SMS / OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
CIP_DEBUG_OTP=false

# Feature flags (defaults; runtime values live in app_configs)
FEATURE_ANONYMOUS_REPORTING=true
FEATURE_AI_ENABLED=true
FEATURE_VIDEO_MANDATORY=true
FEATURE_DUPLICATE_DETECTION=true
FEATURE_FRAUD_DETECTION=true

# Files
MEDIA_MAX_PHOTOS=10
MEDIA_MAX_VIDEO_SECONDS=5
MEDIA_MIN_VIDEO_SECONDS=3
MEDIA_UPLOAD_BANDWIDTH_MB_PER_HOUR=100

{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "void_return": true,
        "no_unused_imports": true,
        "no_useless_else": true,
        "no_useless_return": true,
        "blank_line_before_statement": {
            "statements": ["return", "throw", "if", "foreach", "for", "while", "try"]
        }
    }
}

# Per-project PHP + local dev server config (convention file)
# NOTE: phpenv reads .php-version for the runtime; .phpenv is OUR convention record
# (committed, shared) so parallel `php artisan serve` across projects don't collide.
# The functional value is mirrored into .env as SERVER_PORT (Laravel reads it by default).
PHP_VERSION=8.4
SERVE_PORT=7002
FRONTEND_PORT=4000

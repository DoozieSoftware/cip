APP_NAME="Civic Intelligence Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cip-api.dgisipl.com
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

APP_LIVEWIRE=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ─── MySQL (cPanel) ────────────────────────────────────────
# Replace with your cPanel MySQL database credentials.
# DB_HOST is usually "localhost" on cPanel shared hosting.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=YOUR_CPANEL_DB_NAME
DB_USERNAME=YOUR_CPANEL_DB_USER
DB_PASSWORD=YOUR_CPANEL_DB_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_ENGINE=InnoDB
DB_STRICT=true

# ─── Queue: database driver (no Redis needed) ──────────────
# A cPanel cron job runs `php artisan schedule:run` every
# minute, which dispatches the queue worker
# (`queue:work --stop-when-empty`) via console.php.
QUEUE_CONNECTION=database

# ─── Cache: file driver (no Redis needed) ──────────────────
CACHE_STORE=file

# ─── Session: database driver ──────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Filesystem: local disk (no MinIO needed) ──────────────
# Evidence media is stored under storage/app/media/ on the
# shared hosting filesystem. The MediaStorageService resolves
# CIP_MEDIA_DISK=local → media_local disk automatically.
FILESYSTEM_DISK=local
CIP_MEDIA_DISK=local
CIP_MEDIA_SCANNER=clamav

# ─── Broadcast (not used in pilot) ─────────────────────────
BROADCAST_DRIVER=log

# ─── Mail (configure with cPanel SMTP later) ───────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@cip.dgisipl.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Sanctum (set to your production domain) ───────────────
SANCTUM_STATEFUL_DOMAINS=cip.dgisipl.com,cip-api.dgisipl.com
SESSION_DOMAIN=.dgisipl.com

# ─── Cache prefix ──────────────────────────────────────────
CACHE_PREFIX=cip_

# ─── Horizon (disabled — requires Redis) ───────────────────
# Horizon is not used on cPanel. The database queue + cron
# worker replaces it entirely.
HORIZON_PREFIX=cip_horizon:

# ─── AI provider defaults ──────────────────────────────────
# The active provider is controlled by the ai_provider_configs
# table (seeded by AiProvidersSeeder). The Modal vision model
# endpoint is the primary provider for the pilot.
AI_DEFAULT_PROVIDER=modal-vision

# Modal.com vLLM endpoint (vision-capable model)
# Modal proxy auth uses Modal-Key / Modal-Secret headers.
# SECRETS: leave blank here. Set the real values directly in the
# server's ~/cip/.env (never commit them). The deploy merge keeps
# the server's existing value whenever this template is blank.
AI_MODAL_BASE_URL=https://akshayjoshi999--cip-vision-v3-serve.modal.run
AI_MODAL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
AI_MODAL_KEY=
AI_MODAL_SECRET=

# ─── SMS / OTP ─────────────────────────────────────────────
# Pilot uses log driver (OTP appears in laravel.log). Switch
# to a real SMS gateway before going live.
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
CIP_NOTIFICATIONS_SMS_DRIVER=log

# Demo mode: return the OTP in the /auth/send-otp response so
# the login page can auto-fill it. Disable for production.
CIP_DEBUG_OTP=true

# ─── Feature flags ─────────────────────────────────────────
FEATURE_ANONYMOUS_REPORTING=true
FEATURE_AI_ENABLED=true
FEATURE_VIDEO_MANDATORY=false
FEATURE_DUPLICATE_DETECTION=true
FEATURE_FRAUD_DETECTION=true
CIP_DEMO_MODE=true

# ─── Files ─────────────────────────────────────────────────
MEDIA_MAX_PHOTOS=10
MEDIA_MAX_VIDEO_SECONDS=5
MEDIA_MIN_VIDEO_SECONDS=3
MEDIA_UPLOAD_BANDWIDTH_MB_PER_HOUR=100

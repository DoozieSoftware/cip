# Backend API base URL.
VITE_API_BASE=https://cip-api.dgisipl.com/api/v1
VITE_API_BASE_URL=https://cip-api.dgisipl.com/api/v1

# Web Push (VAPID) public key (base64url, no padding).
# Must be the public key paired with the private key the Laravel
# backend uses to send push notifications. Leave empty to disable
# push subscription at runtime (subscribeToPush returns
# { ok: false, reason: 'subscription_failed' }).
VITE_VAPID_PUBLIC_KEY=BNqWPWTS8SziFJjKgN2sD8_WV2pZ39Q0jyucmC6uQd_Skc_i64s8xJkn7g6MkWQ5bDrJ05Mnhxujxp7oBLM6BbM
